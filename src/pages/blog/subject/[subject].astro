---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import { normalizeSubject, slugifySubject } from '../../../lib/blog-utils';

export const prerender = true;

export async function getStaticPaths() {
	const allPosts = await getCollection('blog');
	const subjects = new Map();

	allPosts.forEach((post) => {
		const subject = normalizeSubject(post.data.subject);
		subjects.set(subject, slugifySubject(subject));
	});

	return Array.from(subjects.values()).map((subject) => ({
		params: { subject },
	}));
}

const subjectParam = Astro.params.subject ?? '';
const allPosts = (await getCollection('blog'))
	.map((post) => ({
		...post,
		slug: post.id.replace(/\.mdx?$/, ''),
		subject: normalizeSubject(post.data.subject),
	}));

const subjectLookup = new Map(
	allPosts.map((post) => [slugifySubject(post.subject), post.subject])
);

const subjectName = subjectLookup.get(subjectParam) ?? subjectParam.replace(/-/g, ' ');

const posts = allPosts
	.filter((post) => slugifySubject(post.subject) === subjectParam)
	.sort((a, b) => {
		const aOrder = a.data.order;
		const bOrder = b.data.order;
		if (aOrder !== undefined && bOrder !== undefined) return aOrder - bOrder;
		if (aOrder !== undefined) return -1;
		if (bOrder !== undefined) return 1;
		const aDate = (a.data.updatedDate ?? a.data.pubDate).valueOf();
		const bDate = (b.data.updatedDate ?? b.data.pubDate).valueOf();
		return bDate - aDate;
	});

const pageTitle = posts.length
	? `${subjectName} posts`
	: 'Subject not found';
---

<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={`Blog posts for ${subjectName}`} />
		<style>
			main {
				width: 960px;
			}
			.page-header {
				margin-bottom: 2rem;
			}
			.page-header h1 {
				margin: 0 0 0.5rem 0;
			}
			.post-list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				gap: 1rem;
			}
			.post-card {
				padding: 1rem;
				border: 1px solid rgba(var(--black), 0.12);
				border-radius: 12px;
			}
			.post-card a {
				text-decoration: none;
				color: inherit;
			}
			.post-meta {
				display: flex;
				justify-content: space-between;
				flex-wrap: wrap;
				gap: 0.75rem;
				color: rgb(var(--gray));
			}
			.back-link {
				display: inline-block;
				margin-top: 1.5rem;
				color: rgb(var(--accent));
				text-decoration: none;
			}
			.back-link:hover {
				text-decoration: underline;
			}
			@media (max-width: 720px) {
				main {
					width: calc(100% - 2em);
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-header">
				<h1>{subjectName}</h1>
				<p>{posts.length > 0 ? `${posts.length} post${posts.length === 1 ? '' : 's'} under this subject.` : 'No posts found for this subject.'}</p>
			</section>
			{posts.length > 0 ? (
				<ul class="post-list">
					{posts.map((post) => (
						<li class="post-card">
							<a href={`/blog/${post.slug}/`}>
								<h2>{post.data.title}</h2>
								<div class="post-meta">
									<span><FormattedDate date={post.data.updatedDate ?? post.data.pubDate} /></span>
									<span>{post.data.description}</span>
								</div>
							</a>
						</li>
					))}
				</ul>
			) : null}
			<a class="back-link" href="/blog?view=subject">← Back to all subjects</a>
		</main>
		<Footer />
	</body>
</html>